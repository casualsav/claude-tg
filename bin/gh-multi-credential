#!/usr/bin/env bash
# gh-multi-credential — a git credential helper that routes github.com HTTPS auth to the
# right gh-authenticated account by repository OWNER. Lets multiple GitHub accounts work
# SIMULTANEOUSLY with one `gh auth login` per account — no active-account switching, so it
# is concurrency-safe across parallel sessions (unlike `gh auth switch`).
#
# Why: gh's own credential helper (`gh auth git-credential`) only ever serves the ACTIVE
# account's token, so any HTTPS push to github.com authenticates as whoever happens to be
# active. This instead picks the token per repo via `gh auth token -u <account>`, which
# returns ANY logged-in account's token regardless of which is active.
#
# Install to a STABLE path (NOT the version-keyed plugin cache — the git config below points at
# it by absolute path), then enable for github.com:
#   install -m 755 bin/gh-multi-credential ~/.local/bin/gh-multi-credential
#   git config --global credential.https://github.com.useHttpPath true
#   git config --global --unset-all credential.https://github.com.helper
#   git config --global --add        credential.https://github.com.helper ""
#   git config --global --add        credential.https://github.com.helper "!$HOME/.local/bin/gh-multi-credential"
# (the empty "" entry resets any inherited helper so only this one answers for github.com.)
#
# By default the repo owner IS the account (casualsav/repo -> casualsav). For orgs or forks
# you push as a different user, add overrides to ~/.config/gh-multi-credential.map, one per
# line "owner=account". Unknown owners fall back to gh's active account, so cloning anything
# else still works. Revert: re-add the gh helper line and unset useHttpPath.
[ "${1:-}" = "get" ] || exit 0          # only answer 'get'; gh stores/erases nothing here

host=""; path=""
while IFS='=' read -r k v; do
  [ -z "$k" ] && break                  # blank line terminates the request
  case "$k" in host) host=$v ;; path) path=$v ;; esac
done
[ "$host" = "github.com" ] || exit 0    # let other helpers handle non-GitHub hosts

owner=${path%%/*}
acct="$owner"
map="$HOME/.config/gh-multi-credential.map"
if [ -n "$owner" ] && [ -f "$map" ]; then
  m=$(grep -E "^${owner}=" "$map" 2>/dev/null | head -1 | cut -d= -f2-)
  [ -n "$m" ] && acct="$m"
fi

token=""
[ -n "$acct" ] && token=$(gh auth token -u "$acct" 2>/dev/null)
if [ -z "$token" ]; then                # owner isn't one of our accounts — use the active one
  acct=""
  token=$(gh auth token 2>/dev/null)
fi
[ -n "$token" ] || exit 0               # no token at all — stay silent, let git try elsewhere

[ -n "$acct" ] && printf 'username=%s\n' "$acct"
printf 'password=%s\n' "$token"
exit 0
